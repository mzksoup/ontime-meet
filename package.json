{
  "name": "ontime-meet",
  "type": "module",
  "version": "1.0.0",
  "description": "Chrome extension that automatically opens Google Calendar meet links and event URLs",
  "scripts": {
    "test:dev": "vitest",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "preversion": "node ./scripts/bump-manifest.cjs $npm_new_version && git add manifest.json",
    "prebuild": "rm -rf dist dist.zip",
    "build": "tsc && vite build",
    "postbuild": "zip -r dist.zip dist",
    "dev": "vite",
    "preview": "vite preview"
  },
  "repository": "mzksoup/ontime-meet",
  "author": "mzksoup",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^1.0.13",
    "@playwright/test": "^1.30.0",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@vitejs/plugin-react": "^2.0.0",
    "ts-loader": "^9.3.0",
    "typescript": "^5.0.0",
    "vite": "^3.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.9.0",
    "@emotion/styled": "^11.8.1",
    "@mui/icons-material": "^6.0.0",
    "@mui/lab": "^5.0.0-alpha.98",
    "@mui/material": "^6.0.0",
    "get-urls": "^12.0.0",
    "ical.js": "^2.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
